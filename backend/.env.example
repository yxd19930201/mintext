# Copy this file to .env and fill in your values
APP_NAME=minitext
APP_ENV=development
DEBUG=true

# Database: SQLite (dev) or PostgreSQL (prod)
DATABASE_URL=sqlite+aiosqlite:///./minitext.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/minitext

# JWT
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# AI (reserved)
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o
